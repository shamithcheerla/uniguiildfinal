rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Registrations
    // ===============================================================
    match /registrations/{registrationId} {
      // Allow reading if authenticated. In a real app, we'd restrict students to their own.
      allow read: if isAuthenticated();
      
      // Allow creating if the studentId matches the authenticated user
      allow create: if isAuthenticated() && request.resource.data.studentId == request.auth.uid;
      
      // Allow updating (for attendance) if authenticated
      allow update: if isAuthenticated();
      
      allow delete: if false;
    }
  }
}
