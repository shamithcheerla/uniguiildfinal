{
  "entities": {
    "Registration": {
      "title": "Registration",
      "description": "A record of a student's registration for an event, including attendance status.",
      "type": "object",
      "properties": {
        "eventId": { "type": "string", "description": "The ID of the event." },
        "studentId": { "type": "string", "description": "The ID of the student." },
        "studentName": { "type": "string", "description": "The name of the student." },
        "eventName": { "type": "string", "description": "The name of the event." },
        "registeredAt": { "type": "string", "format": "date-time", "description": "When the student registered." },
        "attended": { "type": "boolean", "description": "Whether the student attended the event." },
        "attendedAt": { "type": "string", "format": "date-time", "description": "When the student's attendance was marked." },
        "scannedBy": { "type": "string", "description": "The ID of the volunteer/coordinator who scanned the QR code." }
      },
      "required": ["eventId", "studentId", "registeredAt", "attended"]
    }
  },
  "firestore": {
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Collection of event registrations."
    }
  }
}
